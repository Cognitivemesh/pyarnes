#!/usr/bin/env python3
"""Claude Code PostToolUse hook — audit trail + output secret scan + budget tick.

Reads a JSON event from stdin and:

1. Appends the tool call to ``.pyarnes/agent_tool_calls.jsonl`` via
   ``ToolCallLogger`` (the shipped runtime uses the same schema, so
   adopters can grep both streams with one query).
2. Scans the tool response for secrets via ``SecretLeakGuardrail``.
   CC's PostToolUse contract does not permit rewriting the response, so
   a detected secret is logged to ``.claude/pyarnes/violations.jsonl``
   and the hook returns ``{"decision": "block"}`` so the model stops
   reasoning over leaked material.
3. Increments the per-session ``Budget`` counter so the ``Stop`` hook
   can force session end when caps are hit.
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

from pyarnes_core import Budget, Lifecycle
from pyarnes_core.errors import UserFixableError
from pyarnes_guardrails import SecretLeakGuardrail, Violation, append_violation
from pyarnes_harness import ToolCallLogger

_LOG_DIR = Path(".pyarnes")
_LOG_DIR.mkdir(exist_ok=True)
_STATE_DIR = Path(".claude/pyarnes")
_STATE_DIR.mkdir(parents=True, exist_ok=True)
_OUTPUT_SCANNER = SecretLeakGuardrail()


def _checkpoint_path(session_id: str | None) -> Path:
    return _STATE_DIR / f"checkpoint-{session_id or 'default'}.json"


def main() -> int:
    """Entry point; blocks only when the output contains a detected secret."""
    event = json.load(sys.stdin)
    tool = event.get("tool_name", "unknown")
    session_id = event.get("session_id")
    response = event.get("tool_response", "")

    # 1. Append to the audit trail.
    logger = ToolCallLogger(path=_LOG_DIR / "agent_tool_calls.jsonl")
    started_raw = event.get("started_at")
    finished_raw = event.get("finished_at")
    duration: float | None = None
    if isinstance(started_raw, (int, float)) and isinstance(finished_raw, (int, float)):
        duration = float(finished_raw) - float(started_raw)
    logger.log_call(
        tool,
        event.get("tool_input", {}),
        result=str(response),
        is_error=bool(event.get("is_error", False)),
        started_at=str(started_raw) if started_raw is not None else None,
        finished_at=str(finished_raw) if finished_raw is not None else None,
        duration_seconds=duration,
    )

    # 2. Scan the output for secrets.
    try:
        _OUTPUT_SCANNER.check(tool, {"output": response})
    except UserFixableError as exc:
        append_violation(
            Violation(
                guardrail="SecretLeakGuardrail",
                tool=tool,
                reason=str(exc),
                hook="PostToolUse",
                session_id=session_id,
            )
        )
        # PostToolUse cannot redact the response; blocking forward motion
        # is the only signal the model receives that something was wrong.
        print(json.dumps({"decision": "block", "reason": str(exc)}))
        return 0

    # 3. Bump the budget counter.
    path = _checkpoint_path(session_id)
    lifecycle = Lifecycle.load(path) if path.is_file() else Lifecycle(metadata={"session_id": session_id or ""})
    budget = lifecycle.budget or Budget()
    lifecycle.budget = budget.consume(calls=1, seconds=duration or 0.0)
    lifecycle.dump(path)

    return 0


if __name__ == "__main__":
    sys.exit(main())
