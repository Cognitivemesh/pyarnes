#!/usr/bin/env python3
"""Claude Code SessionEnd hook — finalise the Lifecycle checkpoint.

Loads the in-flight checkpoint (if any), transitions it to the
terminal ``COMPLETED`` phase, and dumps it back to disk so the next
``SessionStart`` can surface it via ``additionalContext``. A missing
checkpoint is not an error — it just means no tool calls were recorded
during the session.
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

from pyarnes_core import Lifecycle, Phase

_STATE_DIR = Path(".claude/pyarnes")


def _checkpoint_path(session_id: str | None) -> Path:
    return _STATE_DIR / f"checkpoint-{session_id or 'default'}.json"


def main() -> int:
    """Entry point; persists a terminal-phase snapshot."""
    event = json.load(sys.stdin)
    session_id = event.get("session_id")
    path = _checkpoint_path(session_id)

    lifecycle = Lifecycle.load(path) if path.is_file() else Lifecycle(metadata={"session_id": session_id or ""})
    # Only transition when the state machine allows it — a checkpoint that
    # was already terminal (e.g. failed mid-session) stays terminal.
    if lifecycle.phase in (Phase.INIT, Phase.RUNNING, Phase.PAUSED):
        if lifecycle.phase == Phase.INIT:
            lifecycle.start()
        lifecycle.complete()
    lifecycle.dump(path)
    return 0


if __name__ == "__main__":
    sys.exit(main())
