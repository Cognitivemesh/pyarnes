"""Command-line interface for {{ project_name }}.

Typer app exposing the subcommands appropriate to the chosen adopter shape.
Registered as ``[project.scripts] {{ project_module }} = "{{ project_module }}.cli:app"``
in ``pyproject.toml``; run with ``uv run {{ project_module }} --help``.

The scaffolded commands are placeholders. Fill them in with your domain
logic. {% if adopter_shape != "blank" -%}
For a runnable demo of the shape-specific library stack, see
``scripts/examples/{{ adopter_shape }}/`` (PEP 723 scripts that resolve their
own deps into an isolated env — no project install required).
{%- else -%}
For agent-scaffolding references (pipelines, tool handlers,
guardrails), see ``.claude/agent_kit/``.
{%- endif %}
"""

from __future__ import annotations

import typer

app = typer.Typer(help="{{ project_description }}")

{% if adopter_shape != "blank" -%}
_SEE_DEMO = "TODO: implement. See scripts/examples/{{ adopter_shape }}/ for a reference demo."
{%- else -%}
_SEE_DEMO = "TODO: implement. See .claude/agent_kit/ for agent scaffolding templates."
{%- endif %}


def _stub(summary: str) -> None:
    """Emit a placeholder summary + a pointer at the reference demo location."""
    typer.echo(summary)
    typer.echo(_SEE_DEMO)


{% if adopter_shape == "pii-redaction" -%}
@app.command()
def ingest(input_path: str, output_dir: str = "./out") -> None:
    """Extract text from a document and write it to ``output_dir``."""
    _stub(f"ingest {input_path} -> {output_dir}")


@app.command()
def redact(input_path: str, output_dir: str = "./out") -> None:
    """Run the full PII-redaction pipeline on ``input_path``."""
    _stub(f"redact {input_path} -> {output_dir}")
{%- elif adopter_shape == "s3-sweep" -%}
@app.command()
def download(bucket: str, dest: str = "./out") -> None:
    """Download every object from ``bucket`` into ``dest``."""
    _stub(f"download s3://{bucket} -> {dest}")


@app.command()
def verify(manifest: str = "./out/manifest.json") -> None:
    """Verify every downloaded object against its S3 metadata."""
    _stub(f"verify {manifest}")


@app.command()
def sweep(bucket: str, manifest: str = "./out/manifest.json") -> None:
    """Delete ``bucket`` only after every object is verified."""
    _stub(f"sweep s3://{bucket} (manifest={manifest})")
