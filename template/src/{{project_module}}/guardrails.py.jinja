"""Project-specific guardrails for {{ project_name }}.

``custom_guardrails`` returns the list of ``Guardrail`` subclasses the
pipeline appends to the shared chain. Every guardrail is invoked via
``chain.check(tool_name, arguments)`` — ``AgentLoop`` does not auto-apply
them.
"""

from __future__ import annotations

from pyarnes_core.errors import UserFixableError
from pyarnes_guardrails import Guardrail


{% if adopter_shape == "pii-redaction" -%}
class PiiGuardrail(Guardrail):
    """Reject tool calls that would exfiltrate raw PII via logs or stdout."""

    def check(self, tool_name: str, arguments: dict) -> None:  # noqa: ARG002
        # Adopter tightens this to match their Presidio findings.
        return
{%- elif adopter_shape == "s3-sweep" -%}
class VerificationCompleteGuardrail(Guardrail):
    """Block ``delete_bucket`` unless every object in the manifest is verified."""

    def __init__(self, manifest_path: str = "./out/manifest.json") -> None:
        self.manifest_path = manifest_path

    def check(self, tool_name: str, arguments: dict) -> None:  # noqa: ARG002
        if tool_name != "delete_bucket":
            return
        import json  # noqa: PLC0415
        from pathlib import Path  # noqa: PLC0415

        manifest = json.loads(Path(self.manifest_path).read_text())
        unverified = [o for o in manifest.get("objects", []) if not o.get("verified")]
        if unverified:
            raise UserFixableError(
                message=f"{len(unverified)} objects unverified; refusing delete",
                prompt_hint="Re-run verify or prune unverified entries from the manifest.",
            )


class BucketAllowlistGuardrail(Guardrail):
    """Block any S3 tool call targeting a bucket outside the allowlist."""

    def __init__(self, allowed_buckets: frozenset[str]) -> None:
        self.allowed_buckets = allowed_buckets

    def check(self, tool_name: str, arguments: dict) -> None:  # noqa: ARG002
        bucket = arguments.get("bucket")
        if bucket and bucket not in self.allowed_buckets:
            raise UserFixableError(
                message=f"bucket {bucket!r} not in allowlist",
                prompt_hint=f"Allowed: {sorted(self.allowed_buckets)}",
            )
{%- elif adopter_shape == "rtm-toggl-agile" -%}
class ApiQuotaGuardrail(Guardrail):
    """Rate-limit RTM and Toggl tool calls to avoid quota exhaustion."""

    def __init__(self, calls_per_minute: int = 60) -> None:
        self.calls_per_minute = calls_per_minute

    def check(self, tool_name: str, arguments: dict) -> None:  # noqa: ARG002
        # Adopter wires a real sliding-window counter here.
        return


class SecretScanGuardrail(Guardrail):
    """Refuse tool calls whose arguments contain credential-shaped strings."""

    def check(self, tool_name: str, arguments: dict) -> None:  # noqa: ARG002
        for value in arguments.values():
            text = str(value)
            if "api_key=" in text or "Bearer " in text:
                raise UserFixableError(
                    message="credential-shaped value in tool arguments",
                    prompt_hint="Strip secrets from tool inputs before dispatch.",
                )
{%- endif %}


def custom_guardrails() -> list[Guardrail]:
    """Return the per-project guardrails the pipeline appends to the chain."""
    {% if adopter_shape == "pii-redaction" -%}
    return [PiiGuardrail()]
    {%- elif adopter_shape == "s3-sweep" -%}
    return [BucketAllowlistGuardrail(allowed_buckets=frozenset())]
    {%- elif adopter_shape == "rtm-toggl-agile" -%}
    return [ApiQuotaGuardrail(), SecretScanGuardrail()]
    {%- else -%}
    return []
    {%- endif %}
