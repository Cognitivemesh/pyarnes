[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
license = { text = "MIT" }
requires-python = ">={{ python_version }}"
# `authors` is intentionally omitted — PEP 621 makes it optional.
# Add it later if/when you want to credit the project's authors.
keywords = []
classifiers = [
    "Development Status :: 3 - Alpha",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: {{ python_version }}",
    "Typing :: Typed",
]

# ---------------------------------------------------------------------------
# Runtime dependencies — plain Python utility libs only.
# The scaffolded `src/{{ project_module }}/` does not import pyarnes at
# runtime; pyarnes dev-tool packages are declared in [dependency-groups.dev].
# Shape-specific libraries (kreuzberg, boto3, httpx, pydantic, …) are not
# project-wide dependencies either — they appear as PEP 723 inline metadata
# inside `scripts/examples/<shape>/*.py` and resolve on `uv run`.
# ---------------------------------------------------------------------------
dependencies = [
    "loguru>=0.7",
    "returns>=0.24",
    "toolz>=1.0",
    "more-itertools>=10.5",
    "funcy>=2.0",
    "typer>=0.15",
]

[project.scripts]
{{ project_module }} = "{{ project_module }}.cli:app"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ project_module }}"]

# ---------------------------------------------------------------------------
# pyarnes-tasks configuration — drives the `tasks` CLI.
# `tests` is declared even though the directory does not exist yet;
# the tasks CLI silently skips missing paths so `uv run tasks check` works.
# ---------------------------------------------------------------------------
[tool.pyarnes-tasks]
sources = ["src"]
tests = ["tests"]

# ---------------------------------------------------------------------------
# Dev dependency group
#
# pyarnes dev-tool packages are pulled from the pyarnes monorepo via git URLs.
# No PyPI publishing is involved; `uv sync` clones once and caches the result.
# Pin `pyarnes_ref` to a tag in the pyarnes repo for reproducible builds.
# These power `.claude/hooks/`, `.claude/agent_kit/`, the `tasks` CLI, and
# `tests/bench/` — they are NOT imported by code under `src/`.
# ---------------------------------------------------------------------------
[dependency-groups]
dev = [
    # pyarnes dev-tool packages
    "pyarnes-core       @ git+https://github.com/Cognitivemesh/pyarnes.git@{{ pyarnes_ref }}#subdirectory=packages/core",
    "pyarnes-harness    @ git+https://github.com/Cognitivemesh/pyarnes.git@{{ pyarnes_ref }}#subdirectory=packages/harness",
    "pyarnes-guardrails @ git+https://github.com/Cognitivemesh/pyarnes.git@{{ pyarnes_ref }}#subdirectory=packages/guardrails",
    "pyarnes-bench      @ git+https://github.com/Cognitivemesh/pyarnes.git@{{ pyarnes_ref }}#subdirectory=packages/bench",
    "pyarnes-tasks      @ git+https://github.com/Cognitivemesh/pyarnes.git@{{ pyarnes_ref }}#subdirectory=packages/tasks",
    # Type checking
    "ty>=0.0.1",
    # Testing — kept installed even with no tests/ directory yet.
    # Ask Claude Code: "write a test for X" → the python-test skill
    # scaffolds tests/unit/ and your first test file on demand.
    "pytest>=8.0",
    "pytest-bdd>=8.0",
    "pytest-cov>=6.0",
    "pytest-watch>=4.2",
    "pytest-asyncio>=0.25",
    "pytest-sugar>=1.0",
    "hypothesis>=6.119",
    # Linting & formatting
    "ruff>=0.11",
    "pylint>=3.0",
    # Security analysis
    "bandit>=1.9",
    # Dead-code analysis
    "vulture>=2.14",
    # Code-complexity metrics
    "radon>=6.0",
    # Profiling
    "pyinstrument>=5.0",
    # Docstring generation
    "doq>=0.10",
    # Documentation site
    "mkdocs-material>=9.6",
    "mkdocs-coverage>=1.1",
    # Markdown & YAML
    "pymarkdownlnt>=0.9",
    "mdformat>=1.0",
    "yamllint>=1.35",
    # Process control
    "pexpect>=4.9",
    # File watching
    "watchfiles>=1.0",
]

# ---------------------------------------------------------------------------
# Ruff  –  linting + formatting
# ---------------------------------------------------------------------------
[tool.ruff]
target-version = "py{{ python_version.replace('.', '') }}"
src = ["src", "tests"]
line-length = 120

[tool.ruff.lint]
select = [
    "F", "E", "W", "I", "N", "D", "UP", "B", "A", "S",
    "SIM", "C90", "C4", "T20", "RET", "ARG", "PTH", "PERF",
    "RUF", "ASYNC", "LOG", "G", "FBT", "ICN", "PL", "TRY",
    "FLY", "FURB",
]
ignore = [
    "D100",   # Missing docstring in public module
    "D104",   # Missing docstring in public package
    "D203",   # Conflicts with D211
    "D213",   # Conflicts with D212
    "S101",   # assert used (fine in tests)
    "TRY003", # Long exception messages (acceptable)
]

[tool.ruff.lint.per-file-ignores]
"tests/**/*.py" = [
    "S101",
    "D",
    "ARG",
    "FBT",
    "PLR2004",
]

[tool.ruff.lint.mccabe]
max-complexity = 10

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.ruff.lint.isort]
known-first-party = ["{{ project_module }}"]

[tool.ruff.format]
docstring-code-format = true

# ---------------------------------------------------------------------------
# ty  –  type checking (Astral)
# ---------------------------------------------------------------------------
[tool.ty.environment]
python-version = "{{ python_version }}"

[tool.ty.src]
include = ["src"]

# ---------------------------------------------------------------------------
# pytest
# ---------------------------------------------------------------------------
[tool.pytest.ini_options]
asyncio_mode = "auto"
markers = [
    "slow: marks tests as slow",
    "integration: marks integration tests",
]
addopts = [
    "--strict-markers",
    "--tb=short",
    "-q",
]

# ---------------------------------------------------------------------------
# coverage
# ---------------------------------------------------------------------------
[tool.coverage.run]
source = ["{{ project_module }}"]
branch = true

[tool.coverage.report]
show_missing = true
skip_empty = true
fail_under = 50

# ---------------------------------------------------------------------------
# pylint  –  custom rules only (complement ruff)
# ---------------------------------------------------------------------------
[tool.pylint.main]
load-plugins = []
disable = "all"
enable = [
    "W0611",
    "R0401",
    "E1101",
    "W0221",
]

[tool.pylint.format]
max-line-length = 120

# ---------------------------------------------------------------------------
# bandit  –  security analysis
# ---------------------------------------------------------------------------
[tool.bandit]
targets = ["src"]
severity = "medium"

# ---------------------------------------------------------------------------
# yamllint
# ---------------------------------------------------------------------------
[tool.yamllint]
extends = "default"

# ---------------------------------------------------------------------------
# pymarkdown
# ---------------------------------------------------------------------------
[tool.pymarkdown]
mode = "fix"
