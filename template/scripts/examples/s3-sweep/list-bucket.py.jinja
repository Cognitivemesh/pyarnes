#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">={{ python_version }}"
# dependencies = [
#   "boto3>=1.35",
# ]
# ///
"""List the first page of objects in an S3 bucket.

Usage:
    uv run scripts/examples/s3-sweep/list-bucket.py <bucket-name>

Credentials are read from the standard AWS chain (env vars, profile,
instance metadata). uv resolves `boto3` into an isolated cached env on
first run.
"""

from __future__ import annotations

import sys


def main(bucket: str) -> None:
    """Print up to 1000 keys from ``bucket`` to stdout."""
    import boto3  # noqa: PLC0415

    client = boto3.client("s3")
    response = client.list_objects_v2(Bucket=bucket)
    for obj in response.get("Contents", []):
        sys.stdout.write(f"{obj['Key']}\t{obj['Size']}\n")


if __name__ == "__main__":
    if len(sys.argv) != 2:
        sys.stderr.write("usage: list-bucket.py <bucket-name>\n")
        sys.exit(2)
    main(sys.argv[1])
